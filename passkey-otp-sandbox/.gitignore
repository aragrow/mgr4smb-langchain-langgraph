.env
# .env.example currently contains real credentials in this project and
# must never be committed. Clone-friendly template lives in README.md
# instead.
.env.example
.venv/
logs/
__pycache__/
*.pyc
.pytest_cache/
*.egg-info/
.server.pid
.kb_embeddings.json
# The sandbox shares the parent project's .tokens.json via config.py's
# default path; it should never have its own copy. Belt-and-suspenders.
.tokens.json
# The sandbox auth uses a single DEV_CLIENT_ID from .env — clients.json
# is an mgr4smb-only file and shouldn't appear here.
clients.json
