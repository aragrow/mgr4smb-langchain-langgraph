# --- LangSmith (observability — enabled from day one) ---
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=mgr4smb
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# --- Auth (API layer) ---
JWT_SECRET=
JWT_ALGORITHM=HS256
CLIENTS_FILE=clients.json

# --- Google AI ---
GOOGLE_API_KEY=

# --- GoHighLevel ---
GHL_API_KEY=
GHL_LOCATION_ID=
GHL_CALENDAR_ID=
GHL_ORG_TIMEZONE=America/Chicago
GHL_SLOT_DURATION_MINUTES=30

# --- GoHighLevel OTP custom fields (override per client if needed) ---
# These must match the fieldKey of the custom fields you created in
# GHL under Settings > Custom Fields. The defaults below are the
# Aragrow LLC convention. The values must include the "contact." prefix.
GHL_OTP_CODE_FIELD_KEY=contact.otp_code
GHL_OTP_EXPIRY_FIELD_KEY=contact.otp_expires_at
GHL_OTP_LIFETIME_MINUTES=15

# --- Company contact info (used in escalation messages when OTP fails) ---
# Shown to the user after repeated verification failures so they can
# reach a human representative.
COMPANY_NAME=Aragrow LLC
COMPANY_SUPPORT_EMAIL=
COMPANY_SUPPORT_PHONE=

# --- MongoDB (knowledge base) ---
MONGODB_ATLAS_URI=
MONGODB_DB_NAME=aragrow-llc
MONGODB_COLLECTION=knowledge_base
MONGODB_INDEX_NAME=aragrow_vector_index

# --- MongoDB (shared memory / checkpointer) ---
MONGODB_MEMORY_DB=mgr4smb-memory
MONGODB_MEMORY_COLLECTION=checkpoints

# --- Jobber ---
JOBBER_CLIENT_ID=
JOBBER_CLIENT_SECRET=
JOBBER_TOKENS_FILE=.tokens.json
